---
import { languages } from "../i18n/translations";
import { getLangFromUrl } from "../i18n/utils";

const currentLang = getLangFromUrl(Astro.url);

const langOrder: (keyof typeof languages)[] = ["nn", "en", "no"];

function getNextLang(): keyof typeof languages {
  const currentIndex = langOrder.indexOf(currentLang);
  const nextIndex = (currentIndex + 1) % langOrder.length;
  return langOrder[nextIndex];
}

const nextLang = getNextLang();

function getUrlForLang(lang: keyof typeof languages) {
  const url = Astro.url;
  const pathWithoutLang = currentLang === "nn" 
    ? url.pathname 
    : "/" + url.pathname.split("/").slice(2).join("/");
  
  if (lang === "nn") {
    return pathWithoutLang || "/";
  }
  return `/${lang}${pathWithoutLang}`;
}
---

<a href={getUrlForLang(nextLang)} class="language-link">
  {languages[nextLang]}
</a>

<style>
  .language-link {
    display: inline-block;
  }
</style>
