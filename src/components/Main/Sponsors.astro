---
import { useTranslation, getLocalizedUrl } from "../../i18n/utils";
import type { Sponsor } from "../../program/program";

interface Props {
  sponsors: Sponsor[];
}
const { sponsors } = Astro.props;

const t = useTranslation(Astro.url);
const url = (path: string) => getLocalizedUrl(Astro.url, path);
---

<div class="cont">
  <h2>{t("sponsors.title")}</h2>
  <div class="sponsors-container">
    {
      sponsors.map((sponsor) =>
        sponsor.logo ? (
          <a href={url(sponsor.url)} target="_blank">
            <img
              src={sponsor.logo}
              alt={sponsor.name + " logo"}
              loading="lazy"
            />
          </a>
        ) : (
          <a href={url(sponsor.url)} class="placeholder-card">
            <span class="placeholder-text">{sponsor.name}</span>
          </a>
        ),
      )
    }
  </div>
  <a class="call-to-action" href={url("/sponsor")}>
    {t("sponsors.apply")}
    <img src="/arrow-up-right.svg" alt="arrow up right" />
  </a>
</div>

<style>
  .cont {
    color: #1c1f20;
    padding: 6rem 2rem;
    background-color: #f1f1f1;

    h2 {
      font-size: 3.5rem;
      line-height: 4rem;
      text-align: center;
    }
  }

  .sponsors-container {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-evenly;
    align-items: center;
    margin: 6rem 0;
    gap: 2rem;

    a {
      max-width: 300px;
      min-width: 300px;

      img {
        width: 100%;
        height: auto;
      }
    }

    .placeholder-card {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 300px;
      height: 180px;
      background-color: #e0e0e0;
      border: 3px dashed #999;
      border-radius: 1rem;
      transition: all 0.2s ease;
    }

    .placeholder-card:hover {
      background-color: #d0f0e8;
      border-color: #12e8be;
      transform: scale(1.02);
    }

    .placeholder-text {
      font-size: 1.5rem;
      font-weight: 500;
      color: #666;
      text-align: center;
    }

    .placeholder-card:hover .placeholder-text {
      color: #333;
    }
  }

  .call-to-action {
    width: max-content;
    background-color: #12e8be;
    display: flex;
    gap: 1rem;
    color: #000;
    padding: 1rem 2rem;
    margin: 0 auto 2rem auto;
    border-radius: 4rem;
    border: 1px solid transparent;
  }
  .call-to-action:hover {
    /* border-color: #3f3f3f; */
    background-color: #3ff1ce;
  }

  @media only screen and (min-width: 768px) {
    .cont {
      h2 {
        font-size: 5rem;
        line-height: 2rem;
      }
    }
  }
</style>
