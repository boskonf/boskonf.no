---
import Layout from "../../../layouts/Layout.astro";
import { useTranslation } from "../../../i18n/utils";
const t = useTranslation(Astro.url);
const topics = t<string[]>("cfp.topics.list");
const finalRequirements = t<string[]>("cfp.requirements.finalList");
---

<Layout title={t("cfp.title")}>
  <div class="container">
    <div class="content">
      <h1>{t("cfp.title")}</h1>
      <div class="txtCont">
        <p class="intro">{t("cfp.intro")}</p>
        <p class="highlight">{t("cfp.localSpeakers")}</p>

        <section class="formats">
          <h2>{t("cfp.formats.title")}</h2>
          <div class="format-cards">
            <div class="format-card">
              <h3>{t("cfp.formats.lightning")}</h3>
              <p>{t("cfp.formats.lightningDesc")}</p>
            </div>
            <div class="format-card">
              <h3>{t("cfp.formats.talk")}</h3>
              <p>{t("cfp.formats.talkDesc")}</p>
            </div>
          </div>
        </section>

        <section class="topics">
          <h2>{t("cfp.topics.title")}</h2>
          <ul>
            {topics.map((topic) => <li>{topic}</li>)}
          </ul>
        </section>

        <section class="requirements">
          <h2>{t("cfp.requirements.title")}</h2>
          <p>{t("cfp.requirements.intro")}</p>

          <h3>{t("cfp.requirements.abstractDeadline")}</h3>
          <p>{t("cfp.requirements.abstractDesc")}</p>

          <h3>{t("cfp.requirements.finalDeadline")}</h3>
          <p>{t("cfp.requirements.finalDesc")}</p>
          <ul>
            {finalRequirements.map((req) => <li>{req}</li>)}
          </ul>
        </section>

        <section class="process">
          <h2>{t("cfp.process.title")}</h2>
          <ol>
            <li>{t("cfp.process.submit")}</li>
            <li>{t("cfp.process.review")}</li>
            <li>{t("cfp.process.notify")}</li>
          </ol>
        </section>

        <section class="dates">
          <h2>{t("cfp.dates.title")}</h2>
          <dl class="dates-list">
            <div class="date-item">
              <dt>{t("cfp.dates.abstractDeadline")}</dt>
              <dd>{t("cfp.dates.abstractDeadlineDate")}</dd>
            </div>
            <div class="date-item">
              <dt>{t("cfp.dates.deadline")}</dt>
              <dd>{t("cfp.dates.deadlineDate")}</dd>
            </div>
            <div class="date-item">
              <dt>{t("cfp.dates.notify")}</dt>
              <dd>{t("cfp.dates.notifyDate")}</dd>
            </div>
          </dl>
          <p class="response-info">{t("cfp.dates.responseInfo")}</p>
        </section>

        <section class="diversity">
          <h2>{t("cfp.diversity.title")}</h2>
          <p>{t("cfp.diversity.description")}</p>
        </section>

        <section class="contact">
          <h2>{t("cfp.questions")}</h2>
          <p>
            {t("cfp.contact")}
            <a href="mailto:post@boskonf.no">post@boskonf.no</a>
          </p>
        </section>
      </div>
    </div>
  </div>
</Layout>

<style>
  .content {
    color: #f1f1f1;
    padding: 1rem 2rem;
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .txtCont {
    width: 100%;

    p {
      font-size: 1.2rem;
      font-weight: 300;
    }

    a {
      color: #12e8be;
    }

    a:hover {
      text-decoration: underline;
    }
  }

  .intro {
    font-size: 1.3rem;
    margin-bottom: 1.5rem;
  }

  .highlight {
    background: rgba(18, 232, 190, 0.1);
    border-left: 4px solid #12e8be;
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    font-style: italic;
  }

  section {
    margin: 3rem 0;
  }

  h2 {
    color: #12e8be;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .format-cards {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media only screen and (min-width: 768px) {
    .format-cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  .format-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1.5rem;

    h3 {
      color: #f1f1f1;
      font-size: 1.2rem;
      margin-bottom: 0.5rem;
    }

    p {
      font-size: 1rem;
      margin: 0;
      opacity: 0.9;
    }
  }

  .topics ul {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .topics li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 1.1rem;
  }

  .topics li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: #12e8be;
  }

  .requirements h3 {
    color: #f1f1f1;
    font-size: 1.2rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .requirements ul {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .requirements li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 1.1rem;
  }

  .requirements li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: #12e8be;
  }

  .process ol {
    padding-left: 1.5rem;
  }

  .process li {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    padding-left: 0.5rem;
  }

  .dates-list {
    display: grid;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .date-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1rem 1.5rem;
  }

  .date-item dt {
    font-size: 1rem;
    opacity: 0.7;
    flex-shrink: 0;
    min-width: 12rem;
  }

  .date-item dd {
    font-size: 1.1rem;
    font-weight: 600;
    color: #12e8be;
    margin: 0;
  }

  .response-info {
    font-size: 1rem;
    opacity: 0.85;
    font-style: italic;
  }

  .diversity {
    background: rgba(255, 255, 255, 0.03);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .contact {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .contact h2 {
    font-size: 1.3rem;
  }

  .contact p {
    font-size: 1.1rem;
  }
</style>
